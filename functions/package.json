{
  "name": "epa-functions",
  "private": true,
  "googleCloudServices": [
    "Vertex AI API (Gemini; @google-cloud/vertexai)",
    "Cloud Translation API (REST; glossaryTranslate)",
    "Google Sheets API (googleapis; exportTimelineSheet)",
    "Secret Manager (GOOGLE_TRANSLATE_API_KEY, GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON)",
    "Firebase Cloud Functions 2nd gen (Cloud Run)",
    "Firebase App Check enforcement on callable endpoints"
  ],
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "serve": "npm run build && firebase emulators:start --only functions"
  },
  "dependencies": {
    "@google-cloud/vertexai": "^1.10.0",
    "firebase-admin": "^12.6.0",
    "firebase-functions": "^6.1.0",
    "googleapis": "^144.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
