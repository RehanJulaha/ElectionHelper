{
  "name": "election-process-assistant",
  "version": "0.0.0",
  "private": true,
  "description": "Lok Sabha election education assistant — Google Cloud deployable SPA.",
  "googleCloudServices": {
    "clientAndHosting": [
      "Firebase Hosting",
      "Cloud Firestore (rules; @angular/fire provideFirestore + optional pack overlay)",
      "Firebase App Check (reCAPTCHA Enterprise provider)",
      "Firebase Analytics (Google Analytics 4)",
      "Firebase Performance Monitoring",
      "Firebase Remote Config",
      "Firebase Cloud Functions (HTTPS callable; region asia-south1; CloudFunctionsService)",
      "Google Fonts (fonts.googleapis.com, fonts.gstatic.com)",
      "Google Maps Embed API (optional; enabled when maps embed key is configured)",
      "GitHub Actions → Cloud Build (see .github/workflows/ci.yml, cloudbuild.yaml)"
    ],
    "cloudFunctionsBackend": [
      "Vertex AI API (Gemini; asia-south1; assistantAsk callable)",
      "Cloud Translation API (glossaryTranslate callable)",
      "Google Sheets API (exportTimelineSheet callable; googleapis)",
      "Secret Manager (GOOGLE_TRANSLATE_API_KEY, GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON)",
      "Cloud Run (Firebase Cloud Functions 2nd gen; asia-south1; App Check enforced)",
      "Cloud Logging (firebase-functions/logger)",
      "Cloud Build / Artifact Registry (CI deploy; see cloudbuild.yaml)"
    ]
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --no-watch --browsers=ChromeHeadless",
    "test:vitest": "vitest",
    "test:vitest:rules": "vitest run tests/firestore.rules.spec.ts",
    "test:i18n": "vitest run tests/unit/i18n/translation-keys.spec.ts",
    "test:mutation": "stryker run",
    "test:ci": "vitest run --coverage && ng test --no-watch --browsers=ChromeHeadless",
    "test:firestore-rules": "firebase emulators:exec --only firestore --project demo-epa \"npm run test:vitest:rules\"",
    "lint": "ng lint",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "deploy:firebase:hosting": "ng build && firebase deploy --only hosting",
    "deploy:firebase:firestore": "firebase deploy --only firestore",
    "deploy:firebase:functions": "firebase deploy --only functions",
    "deploy:firebase:all": "ng build && firebase deploy --only hosting,firestore,functions",
    "deploy:cloudbuild": "gcloud builds submit --config=cloudbuild.yaml --substitutions=_FIREBASE_DEPLOY_MODE=hosting ."
  },
  "dependencies": {
    "@angular/common": "^21.2.10",
    "@angular/compiler": "^21.2.10",
    "@angular/core": "^21.2.10",
    "@angular/fire": "^20.0.1",
    "@angular/forms": "^21.2.10",
    "@angular/platform-browser": "^21.2.10",
    "@angular/platform-browser-dynamic": "^21.2.10",
    "@angular/router": "^21.2.10",
    "@angular/service-worker": "^21.2.10",
    "@ngneat/transloco": "^6.0.4",
    "firebase": "^12.12.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.24",
    "@angular-eslint/builder": "^19.0.0",
    "@angular-eslint/eslint-plugin": "^19.0.0",
    "@angular-eslint/eslint-plugin-template": "^19.0.0",
    "@angular-eslint/schematics": "^19.0.0",
    "@angular-eslint/template-parser": "^19.0.0",
    "@angular/cli": "^19.2.24",
    "@angular/compiler-cli": "^19.2.0",
    "@axe-core/playwright": "^4.10.0",
    "@eslint/js": "^9.17.0",
    "@firebase/rules-unit-testing": "^3.0.4",
    "@lhci/cli": "^0.14.0",
    "@percy/cli": "^1.30.1",
    "@percy/playwright": "^1.0.6",
    "@playwright/test": "^1.49.0",
    "@stryker-mutator/core": "^8.6.0",
    "@stryker-mutator/typescript-checker": "^8.6.0",
    "@stryker-mutator/vitest-runner": "^8.6.0",
    "@types/jasmine": "~5.1.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "angular-eslint": "^19.0.0",
    "eslint": "^9.17.0",
    "firebase-tools": "^13.35.1",
    "http-server": "^14.1.1",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
