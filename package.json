{
  "name": "election-process-assistant",
  "version": "0.0.0",
  "private": true,
  "description": "Lok Sabha election education assistant — Google Cloud deployable SPA.",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --no-watch --browsers=ChromeHeadless",
    "test:vitest": "vitest",
    "test:vitest:rules": "vitest run tests/firestore.rules.spec.ts",
    "test:ci": "vitest run --coverage && ng test --no-watch --browsers=ChromeHeadless",
    "test:firestore-rules": "firebase emulators:exec --only firestore --project demo-epa \"npm run test:vitest:rules\"",
    "lint": "ng lint",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/forms": "^19.2.0",
    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.21",
    "@angular/router": "^19.2.0",
    "@ngneat/transloco": "^6.0.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.24",
    "@angular-eslint/builder": "^19.0.0",
    "@angular-eslint/eslint-plugin": "^19.0.0",
    "@angular-eslint/eslint-plugin-template": "^19.0.0",
    "@angular-eslint/schematics": "^19.0.0",
    "@angular-eslint/template-parser": "^19.0.0",
    "@angular/cli": "^19.2.24",
    "@angular/compiler-cli": "^19.2.0",
    "@axe-core/playwright": "^4.10.0",
    "@eslint/js": "^9.17.0",
    "@firebase/rules-unit-testing": "^3.0.4",
    "@playwright/test": "^1.49.0",
    "@types/jasmine": "~5.1.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "angular-eslint": "^19.0.0",
    "eslint": "^9.17.0",
    "firebase": "^10.14.1",
    "firebase-tools": "^15.15.0",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
