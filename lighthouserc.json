{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "url": ["http://127.0.0.1:4200/"],
      "settings": { "preset": "desktop" }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.75 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.85 }]
      }
    }
  }
}
