rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // App Check enforcement (required for production hardening):
    // 1) Firebase Console → App Check → register the Web app (reCAPTCHA Enterprise).
    // 2) Firebase Console → App Check → APIs → enable *Enforcement* for Cloud Firestore.
    // 3) Fill `appCheckSiteKey` in `src/assets/config/firebase-public.json` at deploy time.
    // The callable `assistantAsk` already sets `enforceAppCheck: true` (functions/src/index.ts).
    // Firestore rules cannot replace console-side App Check enforcement; they constrain
    // which documents are readable once a request reaches the rules layer.
    match /contentPacks/{packId} {
      allow get: if packId == 'india-lok-sabha-published';
      allow list: if false;
      allow create, update, delete: if false;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
