rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /contentPacks/{packId} {
      allow get: if packId == 'india-lok-sabha-published';
      allow list: if false;
      allow create, update, delete: if false;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
